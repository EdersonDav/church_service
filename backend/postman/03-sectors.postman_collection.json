{
  "info": {
    "name": "03 - Setores e Membros",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Adicionar Membro na Igreja",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"user_id\": \"{{user_id}}\",\n  \"role\": \"member\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/churches/{{church_id}}/members", "host": ["{{baseUrl}}"], "path": ["churches", "{{church_id}}", "members"] }
      }
    },
    {
      "name": "2. Criar Setor",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Louvor\",\n  \"description\": \"Equipe de Louvor\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/churches/{{church_id}}/sectors", "host": ["{{baseUrl}}"], "path": ["churches", "{{church_id}}", "sectors"] }
      }
    },
    {
      "name": "3. Adicionar Membro ao Setor",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"church_user_id\": \"{{church_user_id}}\",\n  \"role\": \"leader\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/churches/{{church_id}}/sectors/{{sector_id}}/members", "host": ["{{baseUrl}}"], "path": ["churches", "{{church_id}}", "sectors", "{{sector_id}}", "members"] }
      }
    }
  ],
  "variable": [{ "key": "baseUrl", "value": "http://localhost:5555" }]
}

{
  "info": {
    "name": "05 - Escalas, Tarefas e Indisponibilidade",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Criar Escala",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"date\": \"2024-12-30T19:00:00Z\",\n  \"description\": \"Culto de Celebração\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/churches/{{church_id}}/sectors/{{sector_id}}/scales", "host": ["{{baseUrl}}"], "path": ["churches", "{{church_id}}", "sectors", "{{sector_id}}", "scales"] }
      }
    },
    {
      "name": "2. Adicionar Tarefa na Escala",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Bateria\",\n  \"description\": \"Baterista principal\",\n  \"assigned_to\": \"{{church_user_id}}\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/churches/{{church_id}}/sectors/{{sector_id}}/scales/{{scale_id}}/tasks", "host": ["{{baseUrl}}"], "path": ["churches", "{{church_id}}", "sectors", "{{sector_id}}", "scales", "{{scale_id}}", "tasks"] }
      }
    },
    {
      "name": "3. Indisponibilidade de Ministro",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"reason\": \"Viagem\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/churches/{{church_id}}/sectors/{{sector_id}}/scales/{{scale_id}}/ministers/{{church_user_id}}/unavailable", "host": ["{{baseUrl}}"], "path": ["churches", "{{church_id}}", "sectors", "{{sector_id}}", "scales", "{{scale_id}}", "ministers", "{{church_user_id}}", "unavailable"] }
      }
    }
  ],
  "variable": [{ "key": "baseUrl", "value": "http://localhost:5555" }]
}

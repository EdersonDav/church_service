{
  "info": {
    "name": "02 - Igreja",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Criar Igreja",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Igreja Teste\",\n  \"email\": \"contato@igreja.com\",\n  \"phone\": \"0000000000\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/churches", "host": ["{{baseUrl}}"], "path": ["churches"] }
      }
    },
    {
      "name": "2. Listar Igrejas",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": { "raw": "{{baseUrl}}/churches", "host": ["{{baseUrl}}"], "path": ["churches"] }
      }
    }
  ],
  "variable": [{ "key": "baseUrl", "value": "http://localhost:5555" }]
}
